# Paste these into the single Vercel project (Production + Preview as needed).

# Required
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
NODE_ENV=production

# Optional distributed cache (recommended for better serverless cache hit rate)
UPSTASH_REDIS_REST_URL=https://<your-redis-id>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-token>

# Optional cache tuning
CACHE_TTL_SEARCH=300
CACHE_TTL_PRODUCT=600
CACHE_TTL_AUTOCOMPLETE=3600

# Optional API rate limiting (applies to /api/v1/* routes)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
