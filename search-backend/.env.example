# ─────────────────────────────────────────────────────────────────────────────
# MongoDB — paste your Atlas connection string here
# ─────────────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://rhinestorage_db_user:5MED2AuDS95ZLqsm@convert-mastery.o1u1nnj.mongodb.net/fitting-room?retryWrites=true&w=majority&appName=Convert-Mastery

# ─────────────────────────────────────────────────────────────────────────────
# Upstash Redis — distributed cache (works with Vercel serverless)
# Create a free Redis DB at https://console.upstash.com
# Leave blank to run with in-memory cache only (fine for local dev)
# ─────────────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://<your-redis-id>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-token>

# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# API
# ─────────────────────────────────────────────────────────────────────────────
API_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins (leave empty to allow all in dev)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# Cache TTL (seconds)
# ─────────────────────────────────────────────────────────────────────────────
CACHE_TTL_SEARCH=300
CACHE_TTL_PRODUCT=600
CACHE_TTL_AUTOCOMPLETE=3600

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
